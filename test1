            align-items: center;
            padding: 8px 0;
            border-bottom: 1px dashed #e2e8f0;
            font-size: 0.9rem;
        }

        .list-item:last-child {
            border-bottom: none;
        }

        .list-label {
            color: var(--text-muted);
        }

        .list-value {
            font-weight: 600;
            color: var(--text-main);
            text-align: right;
        }

        /* Skills/Tags */
        .tags-container {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 8px;
        }

        .tag {
            background: var(--primary-light);
            color: var(--primary-dark);
