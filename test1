        }

        .student-school {
            font-size: 0.9rem;
            opacity: 0.9;
            font-weight: 300;
        }

        .student-class {
            display: inline-block;
            background: rgba(255, 255, 255, 0.25);
            padding: 3px 12px;
            border-radius: 12px;
            font-size: 0.8rem;
            margin-top: 6px;
            font-weight: 500;
        }

        /* Card Content */
        .card-body {
            padding: 24px;
        }

        /* Motto Section */
        .motto-section {
            background: var(--primary-light);
            border-left: 4px solid var(--primary);
            padding: 12px 16px;
            border-radius: 0 12px 12px 0;
            margin-bottom: 24px;
            font-style: italic;
            color: var(--primary-dark);
            font-size: 0.95rem;
            text-align: center;
        }

        /* Section Styling */
        .section-title {
            font-size: 0.95rem;
            color: var(--primary-dark);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
            border-bottom: 2px solid var(--primary-light);
            padding-bottom: 4px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 24px;
        }

        .info-item {
            display: flex;
            flex-direction: column;
            padding: 8px 12px;
            background: #fafafa;
            border-radius: 8px;
            border: 1px solid #f1f5f9;
        }

        .info-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 2px;
        }

        .info-value {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-main);
        }

        /* Full Width List Info */
        .full-info-list {
            margin-bottom: 24px;
        }

        .list-item {
            display: flex;
